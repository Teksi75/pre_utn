# Supabase — public variables only.
# Do NOT add service role keys, admin keys, or non-public credentials here.
# The app falls back to localStorage when these are not set.

# Public URL of the Supabase project. Format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable / anon key — safe to expose in the browser bundle.
# Used by @supabase/ssr to mint and persist the user session cookie.
# Find it in: Supabase dashboard → Project Settings → API → Project API keys → "anon" / "public".
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ----------------------------------------------------------------------------
# Auth callback URL convention
# ----------------------------------------------------------------------------
# The magic-link email points back at `/auth/callback?code=...`. The route
# handler (src/app/auth/callback/route.ts) exchanges the code for a session
# cookie and redirects the user to `/cuenta`.
#
# For local dev with the default port: http://localhost:3000/auth/callback
# For Vercel previews / production: https://<host>/auth/callback
#
# Configure these allowed redirect URLs in:
#   Supabase dashboard → Authentication → URL Configuration → Redirect URLs
#
# `emailRedirectTo` is hard-coded in `src/lib/supabase/auth.ts` to
# `/auth/callback` (relative path), so Supabase will resolve it against
# the request origin. As long as `/auth/callback` is in the allow-list
# for the origin Supabase sees, the round trip works without further
# configuration.
#
# No additional env var is required for the callback URL itself.